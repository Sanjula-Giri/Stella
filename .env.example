# --- OpenAI Realtime ---
OPENAI_API_KEY=sk-...

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...

# --- Per-business secrets are interpolated into config/businesses/*.yaml ---
# via ${VAR_NAME} syntax. Example for clinic_example.yaml:
CLINIC_EXAMPLE_SMTP_PASSWORD=changeme
CLINIC_EXAMPLE_WEBHOOK_TOKEN=changeme

# --- Google Calendar (only needed once you switch a business off `fake`) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
